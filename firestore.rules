rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { 
      allow read, write: if false; 
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'createdAt', 'updatedAt']) &&
             data.email is string && data.email.size() <= 200 &&
             data.role in ['super_admin', 'admin', 'club_admin', 'user'] &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      // List disabled
      allow create: if isSignedIn() &&
                    request.auth.uid == userId &&
                    isValidUser(incoming()) &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time &&
                    (incoming().role == 'user' || isAdmin() || request.auth.token.email == 'siphom.yati@gmail.com'); // Users can only create themselves as 'user' role by default
      allow update: if isSignedIn() &&
                    request.auth.uid == userId &&
                    isValidUser(incoming()) &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time &&
                    (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'updatedAt']) || isAdmin() || request.auth.token.email == 'siphom.yati@gmail.com');
    }

    function isValidApplication(data) {
      return data.keys().hasAll(['clubName', 'status', 'userId', 'createdAt', 'updatedAt']) &&
             data.clubName is string && data.clubName.size() <= 200 &&
             data.status in ['Pending', 'Under Review', 'Approved', 'Rejected'] &&
             data.userId is string &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    match /applications/{applicationId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin(); // Admin can see all applications
      allow create: if isSignedIn() &&
                    isValidId(applicationId) &&
                    isValidApplication(incoming()) &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time &&
                    incoming().status == 'Pending' &&
                    incoming().userId == request.auth.uid;
      allow update: if isSignedIn() &&
                    isValidApplication(incoming()) &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time &&
                    ((existing().userId == request.auth.uid &&
                    incoming().userId == existing().userId &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['clubName', 'updatedAt'])) || isAdmin());
    }
  }
}
